# Kakao Map API Key (Javascript SDK)
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# Vercel 배포 시 Dashboard의 Environment Variables에서 설정하세요.
# 로컬 개발 시 카카오 플랫폼 → Web 도메인에 http://localhost:3000 등록 필요
KAKAO_MAP_API_KEY=YOUR_KAKAO_MAP_API_KEY_HERE


# CORS 허용 도메인 화이트리스트 (쉼표로 구분, 프로토콜 포함)
# 미설정 시 FRONTEND_URL → VERCEL_PROJECT_PRODUCTION_URL 순서로 자동 추론
# Vercel 배포라면 VERCEL_PROJECT_PRODUCTION_URL이 자동 주입되므로 별도 설정 불필요
# 커스텀 도메인 사용 시에는 아래 항목을 명시적으로 설정할 것
CORS_ALLOWED_ORIGINS=
# 프론트엔드 URL (커스텀 도메인 사용 시 설정)
# 예: https://www.pet-pass.kr
FRONTEND_URL=
# Kakao REST API Key (주소 → 좌표 변환용, convert_xlsx.js에서 사용)
# 발급: 위와 동일한 앱의 REST API 키
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY_HERE

# 정부 API 키 (농림축산식품부_동물등록정보조회)
# 발급: https://www.data.go.kr → 동물등록정보 조회서비스 활용신청
# 미설정 시 테스트 모드(Mock)로 동작합니다.
DATA_GO_KR_API_KEY=YOUR_GOVERNMENT_API_KEY_HERE

# 식품안전나라 API 키 (I1250 서비스 수집용)
# 발급: https://www.foodsafetykorea.go.kr → API 활용신청
FOOD_SAFETY_API_KEY=YOUR_FOOD_SAFETY_API_KEY_HERE

# Supabase 설정 (매장 등록 신청 저장용)
# 발급: https://supabase.com → 프로젝트 Settings → API
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# 배치 스크립트(sync-stores, migrate-to-supabase) 실행 시에만 필요
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
